<Window x:Class="UmbrellaSpoofer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Umbrella Spoofer" Height="820" Width="1280"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Focusable="True" IsTabStop="False"
        Cursor="Arrow">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Border CornerRadius="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="40" ClipToBounds="True">
        <Border.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,32,32" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#080808" Geometry="M0,0 L32,0 32,32 0,32 Z"/>
                        <GeometryDrawing>
                            <GeometryDrawing.Pen>
                                <Pen Brush="#202020" Thickness="1"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="0,31.5" EndPoint="32,31.5"/>
                                    <LineGeometry StartPoint="31.5,0" EndPoint="31.5,32"/>
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="20" Direction="270" Color="#000000" Opacity="0.8" BlurRadius="40"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid x:Name="TitleBar" Grid.Row="0" Height="72" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border CornerRadius="32 32 0 0" Background="#0A0A0A" BorderBrush="#202020" BorderThickness="0 0 0 1" IsHitTestVisible="False"/>
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="32 0" IsHitTestVisible="False">
                    <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource AccentBrush}" Margin="0 0 16 0">
                        <TextBlock x:Name="AppBadgeText" Text="U" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock x:Name="AppTitleText" Text="UMBRELLA SPOOFER" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="AppSubtitleText" Text="Hardware Identity Manager" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 2 0 0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0 0 24 0">
                    <Button x:Name="MinBtn" Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="MinBtn_Click">
                        <Path Data="M0,20 L24,20" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="CloseBtn" Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click">
                        <Path Data="M0,0 L18,18 M0,18 L18,0" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
                </Grid>
            </Grid>
            <Border Grid.Row="1" CornerRadius="0 0 32 32" Background="Transparent" ClipToBounds="True">
            <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0" Padding="32 24" Margin="12 0 0 0">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </TabControl.Resources>
                <TabItem Header="Dashboard">    
                    <Grid Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0 0 0 32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{DynamicResource GlassCard}">
                                <StackPanel>
                                    <TextBlock Text="System Status" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 8"/>
                                    <TextBlock Text="Ready" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                    <TextBlock Text="All systems operational" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0 8 0 0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{DynamicResource GlassCard}">
                                <StackPanel>
                                    <TextBlock Text="Last Spoof" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 8"/>
                                    <TextBlock x:Name="LastSpoofTimeText" Text="Never" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LastSpoofStatusText" Text="No previous activity" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0 8 0 0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Style="{DynamicResource GlassCard}">
                                <StackPanel>
                                    <TextBlock Text="Protection" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 8"/>
                                    <TextBlock Text="Active" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="Anti-detection enabled" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0 8 0 0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1" Style="{DynamicResource GlassCard}" Margin="0,0,0,48">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Hardware Identity Protection" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0 0 0 16"/>
                                    <TextBlock Text="Advanced spoofing technology for complete hardware anonymity" FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="500" Margin="0 0 0 32"/>
                                    <TextBlock Text="Features:" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0 0 0 16"/>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource AccentBrush}" Margin="0 0 12 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Real-time hardware ID masking" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource AccentBrush}" Margin="0 0 12 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Persistent spoofing across reboots" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource AccentBrush}" Margin="0 0 12 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Automatic backup and restore" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource AccentBrush}" Margin="0 0 12 0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Undetectable by anti-cheat systems" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="64 0 0 0">
                                    <Button x:Name="QuickSpoofBtn" Content="QUICK SPOOF" Style="{DynamicResource AccentButton}" Width="160" Margin="0 0 0 16" Click="QuickSpoofBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                
                <TabItem Header="Spoofer">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="520"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{DynamicResource GlassCard}" Margin="0 0 24 0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 24">
                                    <Border Width="4" Height="24" Background="{DynamicResource AccentBrush}" Margin="0 0 16 0"/>
                                    <TextBlock Text="System Logs" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer x:Name="LogsScroll" Grid.Row="1" Margin="0 0 0 24" VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="LogsBox" Background="#0F0F0F" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" FontFamily="Consolas" FontSize="13" IsReadOnly="True" TextWrapping="Wrap" Padding="16" AcceptsReturn="True" VerticalScrollBarVisibility="Disabled"/>
                                </ScrollViewer>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Clear Logs" Style="{DynamicResource SubtleButton}" Width="100" Margin="0 0 8 0" Click="ClearLogsBtn_Click"/>
                                    <Button Content="Export Logs" Style="{DynamicResource SubtleButton}" Width="100" Click="ExportLogsBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Style="{DynamicResource GlassCard}" VerticalAlignment="Top" MaxHeight="480">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="0 0 0 32">
                                    <TextBlock Text="Spoofing Configuration" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0 0 0 8"/>
                                    <TextBlock Text="Configure your hardware identity masking preferences" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" CanContentScroll="True" PanningMode="VerticalOnly">
                                    <StackPanel>
                                    <TextBlock Text="Hardware Components" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0 0 0 24"/>
                                    
                                    <CheckBox x:Name="HwidToggle" Content="Hardware ID (HWID)" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="MacToggle" Content="MAC Address" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <StackPanel Margin="0 0 0 12" Visibility="{Binding ElementName=MacToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Select Network Adapter:" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="24 0 0 4"/>
                                        <ComboBox x:Name="AdapterCombo" Style="{DynamicResource Dropdown}" FontSize="12" Width="300" Margin="24 0 0 0" Height="28"
                                                  DisplayMemberPath="Name" SelectedValuePath="InterfaceIndex"/>
                                    </StackPanel>
                                    
                                    <CheckBox x:Name="BiosToggle" Content="BIOS Serial" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="EfiToggle" Content="EFI Variables" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="MonitorToggle" Content="Monitor Serial" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="RamToggle" Content="RAM Serial" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="DiskToggle" Content="Disk Serials" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="GpuToggle" Content="GPU Identifiers" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="VolumeToggle" Content="Volume Serials" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="TpmToggle" Content="TPM Identity" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="EfiBootToggle" Content="EFI Boot" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="ArpToggle" Content="ARP Cache" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    
                                    <Separator Background="{DynamicResource BorderBrush}" Margin="0 24"/>
                                    
                                    <TextBlock Text="Advanced Options" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0 24 0 24"/>
                                    
                                    <CheckBox x:Name="WifiToggle" Content="Disable WiFi/Bluetooth" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="RestartToggle" Content="Auto Restart After Spoof" Foreground="White" FontSize="15" Margin="0 0 0 20" Style="{DynamicResource Switch}"/>
                                    <CheckBox x:Name="TpmBypassToggle" Content="TPM Bypass (Firmware)" Foreground="White" FontSize="15" Margin="0 0 0 32" IsEnabled="False" Style="{DynamicResource Switch}"/>
                                    
                                    <TextBlock Text="Spoof Mode" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0 0 0 12"/>
                                    <ComboBox x:Name="ModeCombo" Style="{DynamicResource Dropdown}" FontSize="12" Width="300" SelectedIndex="0">
                                        <ComboBoxItem>
                                            <StackPanel>
                                                <TextBlock Text="Temporary Mask" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="Reverts on reboot" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel>
                                                <TextBlock Text="Permanent Mask" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="Persists across reboots" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                    </StackPanel>
                                </ScrollViewer>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 32 0 0">
                                    <Button x:Name="ViewSerialsBtn" Content="View Serials" Style="{DynamicResource SubtleButton}" Width="100" Margin="0 0 12 0" Click="ViewSerialsBtn_Click"/>
                                    <Button x:Name="GenerateBtn" Content="Generate Preview" Style="{DynamicResource SubtleButton}" Width="140" Margin="0 0 12 0" Click="GenerateBtn_Click"/>
                                    <Button x:Name="ApplyBtn" Content="APPLY SPOOF" Style="{DynamicResource AccentButton}" Width="160" Click="ApplyBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                
                
                <TabItem Header="System Info">
                    <Grid Background="Transparent">
                        <Border Style="{DynamicResource GlassCard}" Margin="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 24">
                                    <Border Width="4" Height="24" Background="{DynamicResource AccentBrush}" Margin="0 0 16 0"/>
                                    <TextBlock Text="Hardware Information" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <DataGrid x:Name="CheckerGrid" Grid.Row="1" Style="{StaticResource {x:Type DataGrid}}" AutoGenerateColumns="False" RowHeight="48" GridLinesVisibility="Horizontal" SelectionUnit="CellOrRowHeader" SelectionMode="Extended" FrozenColumnCount="1" ColumnHeaderStyle="{DynamicResource DarkHeader}" IsReadOnly="True">
                                    <DataGrid.Resources>
                                        <Style x:Key="MonoText" TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                        <Style x:Key="DarkHeader" TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#181818"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                            <Setter Property="Padding" Value="16 0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                        <Style x:Key="StatusText" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="Generated">
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                                <Trigger Property="Text" Value="Original">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Component" Binding="{Binding Key}" Width="200">
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkHeader}">
                                                    <Setter Property="ToolTip" Value="Hardware component name"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MonoText}">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Current Value" Binding="{Binding Current}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MonoText}">
                                                    <Setter Property="ToolTip" Value="{Binding Current}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkHeader}">
                                                    <Setter Property="ToolTip" Value="Original serial/value read from system"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Masked Value" Binding="{Binding Masked}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MonoText}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Generated">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="ToolTip" Value="{Binding Masked}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkHeader}">
                                                    <Setter Property="ToolTip" Value="Preview masked value for spoofing"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusText}"/>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.HeaderStyle>
                                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkHeader}">
                                                    <Setter Property="ToolTip" Value="Original or Generated"/>
                                                </Style>
                                            </DataGridTextColumn.HeaderStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 24 0 0">
                                    <Button Content="Check Updates" Style="{DynamicResource SubtleButton}" Width="120" Margin="0 0 8 0" Click="CheckUpdatesBtn_Click"/>
                                    <Button Content="Refresh" Style="{DynamicResource SubtleButton}" Width="120" Margin="0 0 8 0" Click="RefreshBtn_Click"/>
                                    <Button Content="Export Report" Style="{DynamicResource SubtleButton}" Width="120" Click="ExportReportBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                
                <TabItem Header="Backup">
                    <Grid Background="Transparent">
                        <Border Style="{DynamicResource GlassCard}" Margin="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 24">
                                    <Border Width="4" Height="24" Background="{DynamicResource AccentBrush}" Margin="0 0 16 0"/>
                                    <TextBlock Text="Backup" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" CanContentScroll="True" PanningMode="VerticalOnly">
                                    <StackPanel>
                                        <TextBlock Text="Choose what to include in the backup." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 16"/>
                                        <Border Background="#121212" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0 0 0 20">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <CheckBox x:Name="BackupMachineGuid" Content="MachineGuid" IsChecked="True" Foreground="White" FontSize="14" Margin="0 0 0 14" Style="{DynamicResource Switch}"/>
                                                    <CheckBox x:Name="BackupBios" Content="BIOS Serial" IsChecked="True" Foreground="White" FontSize="14" Margin="0 0 0 14" Style="{DynamicResource Switch}"/>
                                                    <CheckBox x:Name="BackupBaseBoard" Content="BaseBoard Serial" IsChecked="True" Foreground="White" FontSize="14" Margin="0 0 0 14" Style="{DynamicResource Switch}"/>
                                                    <CheckBox x:Name="BackupEfi" Content="EFI Version" IsChecked="True" Foreground="White" FontSize="14" Style="{DynamicResource Switch}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <CheckBox x:Name="BackupMonitor" Content="Monitor Serials" IsChecked="True" Foreground="White" FontSize="14" Margin="0 0 0 14" Style="{DynamicResource Switch}"/>
                                                    <CheckBox x:Name="BackupRam" Content="RAM Serials" IsChecked="True" Foreground="White" FontSize="14" Margin="0 0 0 14" Style="{DynamicResource Switch}"/>
                                                    <CheckBox x:Name="BackupMac" Content="MAC Addresses" IsChecked="True" Foreground="White" FontSize="14" Margin="0 0 0 14" Style="{DynamicResource Switch}"/>
                                                    <CheckBox x:Name="BackupEdid" Content="Registry EDID Snapshots" IsChecked="True" Foreground="White" FontSize="14" Style="{DynamicResource Switch}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Border Background="#121212" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="Auto Backup" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0 0 0 8"/>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <CheckBox x:Name="AutoBackupToggle" Content="Enable auto backup" Foreground="White" FontSize="14" Margin="0 0 16 0" Style="{DynamicResource Switch}"/>
                                                    <ComboBox x:Name="AutoBackupInterval" Style="{DynamicResource Dropdown}" FontSize="12" Width="180" SelectedIndex="1">
                                                        <ComboBoxItem Content="Every 15 minutes"/>
                                                        <ComboBoxItem Content="Every 1 hour"/>
                                                        <ComboBoxItem Content="Every 6 hours"/>
                                                        <ComboBoxItem Content="Every 24 hours"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <TextBlock x:Name="BackupFolderText" Text="Backup folder: " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 12 0 0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 24 0 0">
                                    <Button x:Name="RestoreBtn" Content="Restore Backup" Style="{DynamicResource SubtleButton}" Width="140" Margin="0 0 12 0" Click="RestoreBtn_Click"/>
                                    <Button x:Name="BackupBtn" Content="Create Backup" Style="{DynamicResource AccentButton}" Width="160" Click="BackupBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Settings">
                    <Grid Background="Transparent">
                        <Border Style="{DynamicResource GlassCard}" Margin="24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 24">
                                    <Border Width="4" Height="24" Background="{DynamicResource AccentBrush}" Margin="0 0 16 0"/>
                                    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" CanContentScroll="True" PanningMode="VerticalOnly">
                                    <StackPanel>
                                        <TextBlock Text="App Behavior" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0 0 0 12"/>
                                        <CheckBox x:Name="StartMinimizedToggle" Content="Start minimized" Foreground="White" FontSize="14" Margin="0 0 0 12" Style="{DynamicResource Switch}"/>
                                        <CheckBox x:Name="CloseToTrayToggle" Content="Close to tray" Foreground="White" FontSize="14" Margin="0 0 0 12" Style="{DynamicResource Switch}"/>
                                        <CheckBox x:Name="RememberTabToggle" Content="Remember last tab" Foreground="White" FontSize="14" Margin="0 0 0 12" Style="{DynamicResource Switch}"/>
                                        <CheckBox x:Name="StartWithWindowsToggle" Content="Start with Windows" Foreground="White" FontSize="14" Style="{DynamicResource Switch}"/>

                                        <Separator Background="{DynamicResource BorderBrush}" Margin="0 24"/>

                                        <TextBlock Text="System Info" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0 0 0 12"/>
                                        <CheckBox x:Name="AutoRefreshToggle" Content="Auto refresh system info" Foreground="White" FontSize="14" Margin="0 0 0 12" Style="{DynamicResource Switch}"/>
                                        <ComboBox x:Name="AutoRefreshInterval" Style="{DynamicResource Dropdown}" FontSize="12" Width="200" SelectedIndex="1">
                                            <ComboBoxItem Content="Every 1 minute"/>
                                            <ComboBoxItem Content="Every 5 minutes"/>
                                            <ComboBoxItem Content="Every 15 minutes"/>
                                            <ComboBoxItem Content="Every 30 minutes"/>
                                        </ComboBox>
                                    </StackPanel>
                                </ScrollViewer>
                                <Grid Grid.Row="2" Margin="0 24 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24 0 0 0">
                                        <TextBlock Text="Made by Nikolis Security" FontSize="12" Foreground="#AAAAAA" Margin="0 0 0 4"/>
                                        <TextBlock Text="System Spoofer" FontSize="10" Foreground="#666666"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="SaveSettingsBtn" Content="Save Settings" Style="{DynamicResource AccentButton}" Width="160" Click="SaveSettingsBtn_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
            </Border>
        </Grid>
    </Border>
</Window>
